#!/usr/bin/env bash
# SessionStart hook for the zcode-auto plugin.
#
# Injects the compact Auto protocol (the using-auto skill body) into every
# session start so the orchestrator behavior is always on. Self-derives the
# plugin root from the script's own location.
#
# CRITICAL: the agent's cwd at session start is the USER'S PROJECT, not the
# plugin root. The skill bodies reference sibling files (personas/<name>.md,
# assets/*.md) as bare relative paths, which would resolve against the user's
# project and fail. This hook is the one place that knows the absolute plugin
# root at inject time, so it rewrites those tokens to absolute paths in the
# injected context. See assets/delegation-guide.md (path resolution note).
#
# Output contract (per platform), to stdout as JSON:
#   - Cursor (CURSOR_PLUGIN_ROOT set):          additional_context (snake_case)
#   - Claude Code (CLAUDE_PLUGIN_ROOT set,
#                  COPILOT_CLI unset):          hookSpecificOutput.additionalContext
#   - ZCode / Copilot CLI / SDK standard:       additionalContext (top-level)

set -euo pipefail

# Resolve the plugin root. Prefer the ZCODE_PLUGIN_ROOT env var that ZCode
# injects into hook processes (see uSt() in zcode.cjs); fall back to deriving
# it from this script's own location. Do NOT rely on cwd — ZCode spawns hooks
# with cwd = the user's project, not the plugin root.
if [ -n "${ZCODE_PLUGIN_ROOT:-}" ]; then
  PLUGIN_ROOT="$ZCODE_PLUGIN_ROOT"
else
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
fi

SKILL_FILE="${PLUGIN_ROOT}/skills/using-auto/SKILL.md"
if [ ! -f "$SKILL_FILE" ]; then
  # Fail closed without breaking the session, but leave a breadcrumb so a
  # mis-installed plugin is diagnosable instead of silently inert.
  echo "zcode-auto: using-auto SKILL.md not found at $SKILL_FILE" >&2
  exit 0
fi

# Inject the whole file (frontmatter included — harmless inside the IMPORTANT
# block, and avoids the fragile sed frontmatter-strip that would truncate on
# any future "---" horizontal rule in the body).
SKILL_BODY=$(cat "$SKILL_FILE")

# Substitute the <plugin-root> placeholder (used throughout the skill bodies
# and assets) with the absolute plugin root. The agent's cwd is the user's
# project; without this, references to personas/ or assets/ would resolve under
# the project and fail. Using a placeholder token avoids shell-quoting traps
# with literal slashes in ${var//pattern/replacement}.
SKILL_BODY="${SKILL_BODY//<plugin-root>/${PLUGIN_ROOT}}"

# Escape the body for JSON embedding.
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

ESCAPED=$(escape_for_json "$SKILL_BODY")

# The absolute root is also stated explicitly so the agent can resolve any
# other plugin-internal path it discovers (e.g. from a skill description).
SESSION_CONTEXT="<EXTREMELY_IMPORTANT>\nYou are running the zcode-auto plugin. Below is your Auto orchestrator protocol — the always-on summary of the 8-step cycle, the critical-thinking and simplicity lenses, claim tags, delegation to Explore personas, and the job-file system. Apply it to every request.\n\nPlugin root (resolve all plugin-internal files under here, NOT the project cwd): ${PLUGIN_ROOT}\n\n${ESCAPED}\n\nFull protocol detail (cycle mechanics, phase rules, cross-session knowledge architecture, delegation recipes): read ${PLUGIN_ROOT}/assets/auto-protocol.md and ${PLUGIN_ROOT}/assets/delegation-guide.md on demand.\n</EXTREMELY_IMPORTANT>"

# Emit the per-platform JSON shape. Uses printf to avoid heredoc quirks.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$SESSION_CONTEXT"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$SESSION_CONTEXT"
else
  # ZCode / Copilot CLI / SDK standard — top-level additionalContext.
  printf '{\n  "additionalContext": "%s"\n}\n' "$SESSION_CONTEXT"
fi

exit 0
